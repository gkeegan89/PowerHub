  </aside>

</div>

<script>
(function () {
  'use strict';

  // ============================================================
  // ESTADO
  // ============================================================
  const tree = document.getElementById('tree');
  const searchInput = document.getElementById('search');
  const searchWrap = document.getElementById('searchWrap');
  const searchResults = document.getElementById('searchResults');
  const clearBtn = document.getElementById('clearBtn');
  const expandAllBtn = document.getElementById('expandAll');
  const collapseAllBtn = document.getElementById('collapseAll');
  const selectionArea = document.getElementById('selectionArea');
  const recentList = document.getElementById('recentList');
  const navCrumbs = document.getElementById('navCrumbs');

  // Último folder expandido por click (referencia para el breadcrumb de navegación)
  let lastExpandedFolder = null;

  // Recientes en memoria (no localStorage — iframes SharePoint a veces lo bloquean)
  const recents = [];
  const MAX_RECENTS = 4;
  let activeResultIdx = -1;

  // ============================================================
  // INDICE DE HOJAS — base para búsqueda y deduplicación futura
  // ============================================================
  // Estructura preparada para escalar: cuando haya múltiples unidades,
  // un mismo código puede aparecer con varias `units`, que se mostrarán
  // agrupadas en la búsqueda (resuelve el punto 2 del agente).
  const leafIndex = (function buildIndex() {
    const idx = new Map(); // code -> { code, desc, en, paths: [{units, path}] }
    tree.querySelectorAll('.leaf').forEach(leaf => {
      const code = leaf.dataset.code;
      const desc = leaf.dataset.desc;
      const en   = leaf.dataset.en;
      const path = computePath(leaf);
      if (!idx.has(code)) {
        idx.set(code, { code, desc, en, paths: [], el: leaf });
      }
      idx.get(code).paths.push({ unit: path[0], path });
    });
    return idx;
  })();

  // ============================================================
  // UTILIDADES
  // ============================================================
  function computePath(el) {
    // Recorre hacia arriba y junta las etiquetas de cada nodo ancestro
    const parts = [];
    let cur = el.closest('li').parentElement.closest('li');
    while (cur) {
      const label = cur.querySelector(':scope > .node > .node-label');
      if (label) parts.unshift(label.textContent.trim());
      cur = cur.parentElement.closest('li');
    }
    return parts;
  }

  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, c => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
    }[c]));
  }

  function highlight(text, term) {
    if (!term) return escapeHtml(text);
    const escaped = escapeHtml(text);
    const safeTerm = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return escaped.replace(new RegExp(safeTerm, 'gi'), m => `<mark>${m}</mark>`);
  }

  // ============================================================
  // BREADCRUMB DE NAVEGACIÓN (arriba del árbol)
  // Refleja el último folder expandido por click. Si ese folder
  // se cerró o ya no está abierto, retrocede al ancestro abierto
  // más profundo. Si no hay nada abierto, muestra estado vacío.
  // ============================================================
  function updateNavCrumbs() {
    // Si el último folder expandido sigue abierto, lo usamos.
    // Si no, buscamos el folder abierto más profundo del árbol.
    let target = null;
    if (lastExpandedFolder && lastExpandedFolder.classList.contains('open') && tree.contains(lastExpandedFolder)) {
      target = lastExpandedFolder;
    } else {
      // Fallback: el folder abierto más profundo
      const openFolders = tree.querySelectorAll('li.open');
      let maxDepth = -1;
      openFolders.forEach(li => {
        const depth = parseInt(li.dataset.level || '0', 10);
        if (depth > maxDepth) {
          maxDepth = depth;
          target = li;
        }
      });
    }

    if (!target) {
      navCrumbs.innerHTML = '<span class="nav-label">Ruta:</span><span class="nav-empty">Ningún nodo expandido</span>';
      return;
    }

    // Armar el path desde la raíz hasta el target (incluido)
    const path = [];
    let cur = target;
    while (cur && cur !== tree) {
      const label = cur.querySelector(':scope > .node > .node-label');
      if (label) path.unshift({ el: cur, text: label.textContent.trim() });
      cur = cur.parentElement.closest('li');
    }

    const html = ['<span class="nav-label">Ruta:</span>'];
    path.forEach((p, i) => {
      if (i > 0) html.push('<span class="nav-sep">›</span>');
      html.push(`<button class="nav-crumb" type="button" data-crumb-idx="${i}">${escapeHtml(p.text)}</button>`);
    });
    navCrumbs.innerHTML = html.join('');

    // Click en un segmento del breadcrumb: scroll al nodo
    navCrumbs.querySelectorAll('.nav-crumb').forEach((btn, i) => {
      btn.addEventListener('click', () => {
        const node = path[i].el.querySelector(':scope > .node');
        if (node) node.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    });
  }

  // ============================================================
  // ÁRBOL: toggle, expandir/colapsar
  // ============================================================
  tree.addEventListener('click', function (e) {
    const node = e.target.closest('.node');
    if (!node) return;
    const li = node.closest('li');

    if (node.classList.contains('is-folder')) {
      li.classList.toggle('open');
      const isOpen = li.classList.contains('open');
      node.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      // Si lo acabamos de abrir, queda como referencia del breadcrumb
      if (isOpen) lastExpandedFolder = li;
      updateNavCrumbs();
    } else if (node.classList.contains('is-leaf')) {
      selectLeaf(node);
    }
  });

  tree.addEventListener('keydown', function (e) {
    const node = e.target.closest('.node');
    if (!node) return;
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      node.click();
    }
  });

  expandAllBtn.addEventListener('click', () => {
    tree.querySelectorAll('li').forEach(li => {
      if (li.querySelector(':scope > ul')) {
        li.classList.add('open');
        const n = li.querySelector(':scope > .node');
        if (n) n.setAttribute('aria-expanded', 'true');
      }
    });
    // Tras expandir todo, no hay un "último click" claro: reseteamos
    // para que updateNavCrumbs use el fallback (folder más profundo)
    lastExpandedFolder = null;
    updateNavCrumbs();
  });

  collapseAllBtn.addEventListener('click', () => {
    tree.querySelectorAll('li').forEach(li => {
      if (li.querySelector(':scope > ul')) {
        li.classList.remove('open');
        const n = li.querySelector(':scope > .node');
        if (n) n.setAttribute('aria-expanded', 'false');
      }
    });
    lastExpandedFolder = null;
    updateNavCrumbs();
  });

  // ============================================================
  // SELECCIÓN: feedback + copiar + breadcrumb (puntos 1 y 3 del agente)
  // ============================================================
  function selectLeaf(leafEl) {
    tree.querySelectorAll('.leaf.selected').forEach(el => el.classList.remove('selected'));
    leafEl.classList.add('selected');

    const code = leafEl.dataset.code;
    const desc = leafEl.dataset.desc;
    const en   = leafEl.dataset.en;
    const path = computePath(leafEl);

    renderSelection({ code, desc, en, path });
    addRecent({ code, desc });
  }

  function renderSelection(sel) {
    selectionArea.innerHTML = `
      <div class="selection-card">
        <div class="sel-code">${escapeHtml(sel.code)}</div>
        <div class="sel-desc">${escapeHtml(sel.desc)}</div>
        <div class="sel-en">${escapeHtml(sel.en)}</div>
        <div class="copy-actions">
          <button class="btn btn-primary" data-copy="code">Copiar código</button>
        </div>
        <div class="copy-feedback" id="copyFeedback">Copiado ✓</div>
      </div>
    `;

    selectionArea.querySelectorAll('[data-copy]').forEach(btn => {
      btn.addEventListener('click', () => {
        copyToClipboard(sel.code);
      });
    });
  }

  function copyToClipboard(text) {
    const fb = document.getElementById('copyFeedback');
    const showOk = () => {
      if (!fb) return;
      fb.classList.add('show');
      setTimeout(() => fb.classList.remove('show'), 1400);
    };

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(showOk).catch(fallbackCopy);
    } else {
      fallbackCopy();
    }

    function fallbackCopy() {
      // Fallback para iframes con permissions-policy restrictiva
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); showOk(); } catch (_) {}
      document.body.removeChild(ta);
    }
  }

  // ============================================================
  // RECIENTES (punto 10 del agente — in-memory, sesión)
  // ============================================================
  function addRecent(item) {
    const existingIdx = recents.findIndex(r => r.code === item.code);
    if (existingIdx >= 0) recents.splice(existingIdx, 1);
    recents.unshift(item);
    if (recents.length > MAX_RECENTS) recents.length = MAX_RECENTS;
    renderRecents();
  }

  function renderRecents() {
    if (recents.length === 0) {
      recentList.innerHTML = '<li class="recent-empty">Aún no hay códigos consultados.</li>';
      return;
    }
    recentList.innerHTML = recents.map(r => `
      <li>
        <button data-code="${escapeHtml(r.code)}">
          <span class="rc-code">${escapeHtml(r.code)}</span>
          <span class="rc-desc">${escapeHtml(r.desc)}</span>
        </button>
      </li>
    `).join('');
    recentList.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const entry = leafIndex.get(btn.dataset.code);
        if (entry) {
          revealAndSelect(entry.el);
        }
      });
    });
  }

  // ============================================================
  // BÚSQUEDA — con resaltado, dedup y filtrado del árbol
  // ============================================================
  function doSearch(term) {
    term = term.trim().toLowerCase();
    if (!term) {
      searchResults.classList.remove('open');
      searchResults.innerHTML = '';
      tree.classList.remove('searching');
      tree.querySelectorAll('li.hidden, li.match-path').forEach(li => {
        li.classList.remove('hidden', 'match-path');
      });
      return;
    }

    // Buscar en el índice (preparado para dedup futuro)
    const hits = [];
    leafIndex.forEach((entry, code) => {
      const haystack = `${code} ${entry.desc} ${entry.en}`.toLowerCase();
      if (haystack.includes(term)) {
        hits.push(entry);
      }
    });

    // Dropdown
    if (hits.length === 0) {
      searchResults.innerHTML = '<div class="search-empty">Sin resultados</div>';
    } else {
      searchResults.innerHTML = hits.slice(0, 20).map((h, i) => {
        const pathStr = h.paths[0].path.join(' › ');
        // Cuando haya múltiples unidades, mostrar resumen entre paréntesis
        const unitsBadge = h.paths.length > 1
          ? `<span class="sr-units">${h.paths.map(p => p.unit).join(', ')}</span>`
          : '';
        return `
          <div class="search-result" data-code="${escapeHtml(h.code)}" data-idx="${i}">
            <div>
              <span class="sr-code">${highlight(h.code, term)}</span>
              <span class="sr-text">${highlight(h.desc, term)}</span>
              ${unitsBadge}
            </div>
            <span class="sr-path">${escapeHtml(pathStr)}</span>
          </div>
        `;
      }).join('');
      searchResults.querySelectorAll('.search-result').forEach(div => {
        div.addEventListener('click', () => {
          const entry = leafIndex.get(div.dataset.code);
          if (entry) revealAndSelect(entry.el);
        });
      });
    }
    searchResults.classList.add('open');

    // Filtrar también el árbol: ocultar hojas que no matchean,
    // marcar el path de las que sí.
    tree.classList.add('searching');
    const matchSet = new Set(hits.map(h => h.el));
    tree.querySelectorAll('li').forEach(li => li.classList.remove('hidden', 'match-path'));
    tree.querySelectorAll('.leaf').forEach(leaf => {
      const li = leaf.closest('li');
      if (matchSet.has(leaf)) {
        // Marcar y expandir todos los ancestros
        let cur = li;
        while (cur && cur !== tree) {
          cur.classList.add('match-path');
          if (cur.querySelector(':scope > ul')) cur.classList.add('open');
          cur = cur.parentElement.closest('li');
        }
      } else {
        li.classList.add('hidden');
      }
    });
    // Ocultar carpetas que quedaron sin hijos visibles
    tree.querySelectorAll('li').forEach(li => {
      const sub = li.querySelector(':scope > ul');
      if (sub && !li.classList.contains('match-path')) {
        li.classList.add('hidden');
      }
    });
  }

  function revealAndSelect(leafEl) {
    // Expandir todos los ancestros
    let cur = leafEl.closest('li').parentElement.closest('li');
    let deepestFolder = null;
    while (cur) {
      cur.classList.add('open');
      const n = cur.querySelector(':scope > .node');
      if (n) n.setAttribute('aria-expanded', 'true');
      if (!deepestFolder) deepestFolder = cur; // primero en la iteración = el más profundo (la hoja se cuelga de él)
      cur = cur.parentElement.closest('li');
    }
    if (deepestFolder) lastExpandedFolder = deepestFolder;
    updateNavCrumbs();

    selectLeaf(leafEl);
    leafEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    // Cerrar dropdown
    searchResults.classList.remove('open');
  }

  searchInput.addEventListener('input', function () {
    searchWrap.classList.toggle('has-value', this.value.length > 0);
    doSearch(this.value);
  });

  searchInput.addEventListener('focus', function () {
    if (this.value.trim().length > 0 && searchResults.innerHTML) {
      searchResults.classList.add('open');
    }
  });

  // Cerrar dropdown al hacer click fuera
  document.addEventListener('click', function (e) {
    if (!searchWrap.contains(e.target)) {
      searchResults.classList.remove('open');
    }
  });

  clearBtn.addEventListener('click', function () {
    searchInput.value = '';
    searchWrap.classList.remove('has-value');
    doSearch('');
    searchInput.focus();
  });

  // Navegación con teclado en el dropdown
  searchInput.addEventListener('keydown', function (e) {
    const results = searchResults.querySelectorAll('.search-result');
    if (results.length === 0) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeResultIdx = Math.min(activeResultIdx + 1, results.length - 1);
      updateActiveResult(results);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeResultIdx = Math.max(activeResultIdx - 1, 0);
      updateActiveResult(results);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      const target = activeResultIdx >= 0 ? results[activeResultIdx] : results[0];
      if (target) target.click();
    } else if (e.key === 'Escape') {
      searchInput.value = '';
      searchWrap.classList.remove('has-value');
      doSearch('');
    }
  });

  function updateActiveResult(results) {
    results.forEach((r, i) => r.classList.toggle('active', i === activeResultIdx));
    if (activeResultIdx >= 0) {
      results[activeResultIdx].scrollIntoView({ block: 'nearest' });
    }
  }

  // ============================================================
  // INIT
  // ============================================================
  // Al arrancar, los 3 niveles raíz están abiertos en el HTML.
  // Mostramos el breadcrumb reflejando esa profundidad inicial.
  updateNavCrumbs();

})();
</script>
</body>
</html>
