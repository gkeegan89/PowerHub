<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modos de falla GADS NERC — clasificación</title>
<style>
  /* =========================================================
     PILOTO — 27 códigos (Sistema de aire de entrada y compresores)
     Rediseño UI sobre la opinión del agente Claude (Chrome).
     Drop-in para iframe SharePoint PowerHub. Sin dependencias.
     ========================================================= */

  :root {
    --bg:            #ffffff;
    --bg-subtle:     #f6f8fb;
    --bg-hover:      #eef2f8;
    --border:        #dde3eb;
    --border-strong: #c4cdda;
    --fg:            #1a1d21;
    --fg-muted:      #5b6470;
    --fg-faint:      #8a93a0;
    --accent:        #1f5fa8;
    --accent-soft:   #e8f0fb;
    --accent-strong: #134a8a;
    --code-bg:       #eef2f7;
    --code-fg:       #134a8a;
    --shadow-sm:     0 1px 2px rgba(20, 30, 50, 0.06);
    --shadow-md:     0 4px 12px rgba(20, 30, 50, 0.08);
    --radius:        6px;
    --mono:          ui-monospace, "SF Mono", "Cascadia Mono", Consolas, Menlo, monospace;
    --sans:          -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;

    /* Tinte sutil por nivel — refuerza jerarquía sin saturar */
    --tint-1: #f5f8fc;
    --tint-2: #f9fbfd;
    --tint-3: #fcfdfe;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }

  body { padding: 16px; }

  /* ---------- Header ---------- */
  .app-header {
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .app-header h1 {
    font-size: 16px;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
  }

  /* ---------- Layout 2 columnas con altura fija ---------- */
  .layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 16px;
    align-items: stretch;
    /* Altura fija: aprovecha el viewport del iframe pero con piso para que no se aplaste */
    height: calc(100vh - 80px);
    min-height: 420px;
  }
  .layout > main,
  .layout > .side-panel {
    display: flex;
    flex-direction: column;
    min-height: 0; /* clave para que el flex permita shrink y aparezca scroll en hijos */
  }
  @media (max-width: 820px) {
    .layout {
      grid-template-columns: 1fr;
      height: auto;
    }
    .side-panel { order: -1; }
  }

  /* ---------- Breadcrumb de navegación (arriba del árbol) ---------- */
  .nav-crumbs {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 4px;
    padding: 8px 12px;
    margin-bottom: 8px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 12px;
    min-height: 32px;
  }
  .nav-crumbs .nav-label {
    color: var(--fg-faint);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    font-size: 10px;
    margin-right: 4px;
  }
  .nav-crumbs .nav-crumb {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    color: var(--accent);
    padding: 2px 6px;
    border-radius: 3px;
    transition: background .1s;
  }
  .nav-crumbs .nav-crumb:hover {
    background: var(--accent-soft);
    text-decoration: underline;
  }
  .nav-crumbs .nav-crumb:last-of-type {
    color: var(--fg);
    font-weight: 600;
    cursor: default;
  }
  .nav-crumbs .nav-crumb:last-of-type:hover {
    background: none;
    text-decoration: none;
  }
  .nav-crumbs .nav-sep {
    color: var(--fg-faint);
    font-size: 11px;
  }
  .nav-crumbs .nav-empty {
    color: var(--fg-faint);
    font-style: italic;
  }

  /* ---------- Toolbar ---------- */
  .toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
  }
  .search-wrap input {
    width: 100%;
    padding: 8px 32px 8px 32px;
    font-size: 14px;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg);
    font-family: inherit;
    transition: border-color .15s, box-shadow .15s;
  }
  .search-wrap input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .search-wrap .search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--fg-faint);
    pointer-events: none;
  }
  .search-wrap .clear-btn {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: var(--fg-faint);
    padding: 4px 6px;
    font-size: 16px;
    line-height: 1;
    border-radius: 4px;
    display: none;
  }
  .search-wrap .clear-btn:hover {
    background: var(--bg-hover);
    color: var(--fg);
  }
  .search-wrap.has-value .clear-btn { display: block; }

  .btn {
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    padding: 7px 12px;
    font-size: 13px;
    cursor: pointer;
    color: var(--fg);
    font-family: inherit;
    transition: background .12s, border-color .12s;
    white-space: nowrap;
  }
  .btn:hover { background: var(--bg-hover); }
  .btn:active { background: var(--border); }
  .btn-primary {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .btn-primary:hover { background: var(--accent-strong); border-color: var(--accent-strong); }

  /* Filtro de unidad — slot listo para escalado */
  .unit-filter {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px 10px;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .unit-filter select {
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 12px;
    color: var(--fg);
    cursor: pointer;
  }
  .unit-filter select:focus { outline: none; }

  /* ---------- Resultados de búsqueda ---------- */
  .search-results {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    max-height: 280px;
    overflow-y: auto;
    z-index: 10;
    display: none;
  }
  .search-results.open { display: block; }
  .search-result {
    padding: 8px 12px;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }
  .search-result:last-child { border-bottom: none; }
  .search-result:hover, .search-result.active { background: var(--accent-soft); }
  .search-result .sr-code {
    font-family: var(--mono);
    font-weight: 600;
    color: var(--code-fg);
    margin-right: 8px;
  }
  .search-result .sr-text { color: var(--fg); }
  .search-result .sr-path {
    display: block;
    font-size: 11px;
    color: var(--fg-faint);
    margin-top: 2px;
  }
  .search-result .sr-units {
    display: inline-block;
    margin-left: 8px;
    font-size: 11px;
    color: var(--fg-muted);
    background: var(--bg-subtle);
    border-radius: 3px;
    padding: 1px 6px;
  }
  .search-empty {
    padding: 12px;
    text-align: center;
    color: var(--fg-faint);
    font-size: 12px;
  }
  mark {
    background: #fff3a8;
    color: inherit;
    padding: 0 1px;
    border-radius: 2px;
  }

  /* ---------- Árbol ---------- */
  .tree, .tree ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tree {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 6px;
    /* Llena el espacio disponible en el flex container, scroll interno si excede */
    flex: 1 1 auto;
    overflow-y: auto;
    min-height: 0;
  }
  .tree ul {
    /* Línea-guía sutil de jerarquía */
    margin-left: 14px;
    padding-left: 12px;
    border-left: 1px solid var(--border);
    display: none;
  }
  .tree li.open > ul { display: block; }

  .tree li { margin: 1px 0; }

  /* Nodo: header clickeable */
  .node {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    border-radius: 4px;
    cursor: pointer;
    user-select: none;
    transition: background .1s;
    color: var(--fg);
  }
  .node:hover { background: var(--bg-hover); }
  .node:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  .chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    color: var(--fg-faint);
    transition: transform .15s;
    flex-shrink: 0;
  }
  .tree li.open > .node .chevron { transform: rotate(90deg); }
  .chevron svg { width: 10px; height: 10px; }

  .node-icon {
    flex-shrink: 0;
    color: var(--fg-muted);
    width: 16px;
    height: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .node-icon svg { width: 14px; height: 14px; }
  .node.is-folder .node-icon { color: var(--accent); }
  .node.is-leaf .node-icon { color: var(--fg-faint); }

  .node-label {
    font-size: 13px;
    color: var(--fg);
  }
  .node.is-folder > .node-label {
    font-weight: 500;
  }
  .node.lvl-1 > .node-label { font-weight: 600; font-size: 14px; }
  .node.lvl-2 > .node-label { font-weight: 600; }

  .node-count {
    margin-left: auto;
    font-size: 11px;
    color: var(--fg-faint);
    background: var(--bg-subtle);
    border-radius: 10px;
    padding: 1px 7px;
  }

  /* Hojas (códigos) */
  .leaf {
    /* mismo .node, pero el contenido cambia */
  }
  .leaf .code-chip {
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--code-fg);
    background: var(--code-bg);
    border-radius: 3px;
    padding: 1px 7px;
    flex-shrink: 0;
  }
  .leaf .leaf-desc {
    font-size: 13px;
    color: var(--fg);
  }
  .leaf .leaf-en {
    font-size: 11px;
    color: var(--fg-faint);
    margin-left: 4px;
    font-style: italic;
  }

  /* Estado seleccionado de una hoja */
  .leaf.selected {
    background: var(--accent-soft) !important;
    box-shadow: inset 2px 0 0 var(--accent);
  }
  .leaf.selected .code-chip {
    background: var(--accent);
    color: white;
  }

  /* Estado de búsqueda: oculta ramas que no matchean */
  .tree.searching li.hidden { display: none; }
  .tree.searching li.match-path > .node { background: var(--accent-soft); }

  /* ---------- Side panel ---------- */
  .side-panel {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .panel-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--fg-muted);
    margin: 0 0 8px;
  }
  /* Selección Actual: altura natural, sin scroll */
  .panel-section.selection {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
  }
  .panel-section.selection #selectionArea {
    flex: 0 0 auto;
  }
  /* Recientes: ocupa el resto, sin scroll (la cantidad de items está acotada) */
  .panel-section.recents {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    min-height: 0;
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .panel-section.recents .recent-list {
    flex: 0 0 auto;
  }

  .selection-empty {
    color: var(--fg-faint);
    font-size: 13px;
    font-style: italic;
  }

  .selection-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px;
  }
  .selection-card .sel-code {
    font-family: var(--mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--code-fg);
    margin-bottom: 4px;
  }
  .selection-card .sel-desc {
    font-size: 13px;
    color: var(--fg);
    line-height: 1.4;
    margin-bottom: 4px;
  }
  .selection-card .sel-en {
    font-size: 12px;
    color: var(--fg-muted);
    font-style: italic;
    margin-bottom: 10px;
  }

  .copy-actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .copy-feedback {
    font-size: 11px;
    color: #1a7a3f;
    margin-top: 6px;
    opacity: 0;
    transition: opacity .15s;
  }
  .copy-feedback.show { opacity: 1; }

  /* Recientes */
  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .recent-list li button {
    width: 100%;
    text-align: left;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 6px 8px;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background .1s;
  }
  .recent-list li button:hover { background: var(--bg-hover); }
  .recent-list .rc-code {
    font-family: var(--mono);
    font-weight: 600;
    color: var(--code-fg);
    flex-shrink: 0;
  }
  .recent-list .rc-desc {
    color: var(--fg-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .recent-empty {
    color: var(--fg-faint);
    font-size: 12px;
    font-style: italic;
  }

  /* dataset sin traducción EN: ocultar líneas en inglés vacías */
  .leaf .leaf-en:empty { display: none; }
  .selection-card .sel-en:empty { display: none; }
</style>
</head>
